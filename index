            <button class="btn-load-preview" onclick="loadPreview(this)">⬇ تحميل المعاينة</button>
          </div>
        </div>
      </div>

    </div>

    <div class="section-nav">
      <button class="snav-btn home" onclick="showSection('home')">🏠 العودة للبداية</button>
      <button class="snav-btn" onclick="showSection('indicators')">→ السابق</button>
    </div>
  </div>
</section>

<!-- IMAGE MODAL -->
<div id="img-modal" onclick="closeImgModal(event)">
  <div class="modal-inner">
    <button class="close-btn" onclick="document.getElementById('img-modal').classList.remove('open')">✕</button>
    <img id="modal-img" src="" alt="صورة العضو">
  </div>
</div>

<!-- FOCUS MODAL -->
<div id="focus-modal">
  <iframe id="focus-frame" src="" loading="lazy" allow="autoplay; fullscreen; clipboard-read; clipboard-write" title="معاينة الملف"></iframe>
  <button class="focus-close" onclick="closeFocus()">✕ إغلاق</button>
</div>

<script>
// ─── PARTICLES ───
(function(){
  const canvas = document.getElementById('bg-canvas');
  const ctx = canvas.getContext('2d');
  let W, H, particles = [];

  function resize(){ W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }
  window.addEventListener('resize', resize);
  resize();

  for(let i=0;i<90;i++){
    particles.push({
      x: Math.random()*99999, y: Math.random()*99999,
      vx: (Math.random()-.5)*.4, vy: (Math.random()-.5)*.4,
      r: Math.random()*1.8+.4,
      a: Math.random()*.6+.1
    });
  }

  function draw(){
    ctx.clearRect(0,0,W,H);
    particles.forEach(p => {
      p.x += p.vx; p.y += p.vy;
      if(p.x<0) p.x=W; if(p.x>W) p.x=0;
      if(p.y<0) p.y=H; if(p.y>H) p.y=0;
      ctx.beginPath();
      ctx.arc(p.x%W, p.y%H, p.r, 0, Math.PI*2);
      ctx.fillStyle = `rgba(56,189,248,${p.a})`;
      ctx.fill();
    });
    // connections
    for(let i=0;i<particles.length;i++){
      for(let j=i+1;j<particles.length;j++){
        const dx=(particles[i].x%W)-(particles[j].x%W);
        const dy=(particles[i].y%H)-(particles[j].y%H);
        const dist=Math.sqrt(dx*dx+dy*dy);
        if(dist<120){
          ctx.beginPath();
          ctx.strokeStyle=`rgba(56,189,248,${.12*(1-dist/120)})`;
          ctx.lineWidth=.6;
          ctx.moveTo(particles[i].x%W,particles[i].y%H);
          ctx.lineTo(particles[j].x%W,particles[j].y%H);
          ctx.stroke();
        }
      }
    }
    requestAnimationFrame(draw);
  }
  draw();
})();

// ─── SECTION NAV ───
function showSection(id){
  document.querySelectorAll('.content-section').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  document.querySelectorAll('.nav-links a').forEach(a => a.classList.remove('active'));
  window.scrollTo({top:0,behavior:'smooth'});
  revealObserver();
}

// ─── TAB ───
function switchTab(btn, id){
  btn.closest('.container').querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  btn.closest('.container').querySelectorAll('.tab-content').forEach(c=>c.style.display='none');
  document.getElementById(id).style.display='grid';
}

// ─── FULLSCREEN ───
function toggleFS(){
  if(!document.fullscreenElement) document.documentElement.requestFullscreen().catch(()=>{});
  else document.exitFullscreen().catch(()=>{});
}

// ─── FILE PREVIEW (lazy) ───
function loadPreview(btn){
  const area = btn.closest('.preview-area');
  const src = area.getAttribute('data-src');
  if(!src || src.includes('YOUR_')) {
    area.innerHTML = '<div class="preview-placeholder"><span class="pi">⚠️</span><span>الرابط غير متوفر — أضف رابطك</span></div>';
    return;
  }
  const iframe = document.createElement('iframe');
  iframe.src = src;
  iframe.loading = 'lazy';
  iframe.allow = 'autoplay; fullscreen; clipboard-read; clipboard-write';
  iframe.title = 'معاينة الملف';
  iframe.style.cssText = 'width:100%;height:100%;border:none;';
  area.innerHTML = '';
  area.appendChild(iframe);
}

function openFile(url){
  if(url.includes('YOUR_')) { alert('يرجى إضافة رابط الملف الفعلي في الكود'); return; }
  window.open(url,'_blank');
}

function openFocus(url){
  if(url.includes('YOUR_')) { alert('يرجى إضافة رابط الملف الفعلي في الكود'); return; }
  const f = document.getElementById('focus-frame');
  f.src = url;
  document.getElementById('focus-modal').classList.add('open');
}

function closeFocus(){
  document.getElementById('focus-modal').classList.remove('open');
  document.getElementById('focus-frame').src='';
}

// ─── IMG MODAL ───
function openImgModal(card){
  const name = card.getAttribute('data-name');
  const imgEl = card.querySelector('img');
  const modal = document.getElementById('img-modal');
  const mImg = document.getElementById('modal-img');
  if(imgEl){ mImg.src = imgEl.src; mImg.alt = name; }
  else { mImg.src=''; mImg.alt=name; mImg.style.display='none';
    // show name fallback
    mImg.style.display='';
  }
  modal.classList.add('open');
}
function closeImgModal(e){
  if(e.target === document.getElementById('img-modal'))
    document.getElementById('img-modal').classList.remove('open');
}

// ─── SCROLL REVEAL ───
function revealObserver(){
  const obs = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{
      if(e.isIntersecting){ e.target.classList.add('visible'); obs.unobserve(e.target); }
    });
  },{threshold:.12});
  document.querySelectorAll('.reveal:not(.visible)').forEach(el=>obs.observe(el));
}
document.addEventListener('DOMContentLoaded', revealObserver);

// ─── TILT ───
document.addEventListener('mousemove', e=>{
  document.querySelectorAll('.info-card, .file-card, .whisper-card, .stat-card').forEach(card=>{
    const rect = card.getBoundingClientRect();
    const cx = rect.left + rect.width/2;
    const cy = rect.top + rect.height/2;
    const dx = (e.clientX - cx) / rect.width;
    const dy = (e.clientY - cy) / rect.height;
    const dist = Math.sqrt(dx*dx+dy*dy);
    if(dist < .9){
      card.style.transform = `perspective(600px) rotateY(${dx*6}deg) rotateX(${-dy*6}deg) translateY(-4px)`;
    } else {
      card.style.transform = '';
    }
  });
});
</script>
</body>
</html>
