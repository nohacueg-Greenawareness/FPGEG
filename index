<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>وعي تربوي أخضر</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&display=swap');

:root {
  --deep: #080f1a;
  --navy: #0d1b2e;
  --card-bg: rgba(13, 27, 46, 0.85);
  --sky: #38bdf8;
  --sky-dim: rgba(56, 189, 248, 0.18);
  --gold: #f0c040;
  --gold-dim: rgba(240, 192, 64, 0.22);
  --green: #34d399;
  --green-dim: rgba(52, 211, 153, 0.15);
  --white: #f0f6ff;
  --muted: #8fa8c4;
  --radius: 18px;
  --shadow: 0 8px 32px rgba(0,0,0,0.45);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  font-family: 'Cairo', 'DIN Next LT Arabic', sans-serif;
  background: var(--deep);
  color: var(--white);
  min-height: 100vh;
  overflow-x: hidden;
  direction: rtl;
}

/* ─── CANVAS PARTICLES ─── */
#bg-canvas {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
}

/* ─── AURORA ─── */
.aurora {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  overflow: hidden;
}
.aurora-blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(90px);
  opacity: 0.13;
  animation: drift 18s ease-in-out infinite alternate;
}
.aurora-blob:nth-child(1) { width: 700px; height: 700px; background: radial-gradient(circle, #38bdf8, transparent 70%); top: -200px; right: -100px; animation-duration: 20s; }
.aurora-blob:nth-child(2) { width: 500px; height: 500px; background: radial-gradient(circle, #34d399, transparent 70%); bottom: -150px; left: -80px; animation-duration: 24s; animation-delay: -5s; }
.aurora-blob:nth-child(3) { width: 400px; height: 400px; background: radial-gradient(circle, #f0c040, transparent 70%); top: 40%; left: 30%; animation-duration: 28s; animation-delay: -10s; }

@keyframes drift {
  0% { transform: translate(0, 0) scale(1); }
  100% { transform: translate(60px, 40px) scale(1.15); }
}

/* ─── NAV ─── */
nav {
  position: fixed;
  top: 0; right: 0; left: 0;
  z-index: 100;
  background: rgba(8, 15, 26, 0.82);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(56,189,248,0.12);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28px;
  height: 62px;
}
.nav-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--sky);
  white-space: nowrap;
}
.nav-logo .leaf { font-size: 1.5rem; }
.nav-links {
  display: flex;
  gap: 4px;
  list-style: none;
}
.nav-links a {
  color: var(--muted);
  text-decoration: none;
  font-size: 0.88rem;
  padding: 6px 12px;
  border-radius: 8px;
  transition: all .2s;
}
.nav-links a:hover, .nav-links a.active {
  color: var(--sky);
  background: var(--sky-dim);
}
.nav-actions { display: flex; gap: 8px; }
.btn-fs {
  background: var(--sky-dim);
  border: 1px solid rgba(56,189,248,0.25);
  color: var(--sky);
  border-radius: 8px;
  padding: 6px 12px;
  cursor: pointer;
  font-size: 0.85rem;
  font-family: inherit;
  transition: all .2s;
}
.btn-fs:hover { background: rgba(56,189,248,0.28); }

/* ─── SECTIONS ─── */
.page-section {
  min-height: 100vh;
  padding: 82px 0 60px;
  position: relative;
  z-index: 1;
}

.container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

/* ─── HERO ─── */
#hero {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.hero-inner { max-width: 760px; }
.hero-badge {
  display: inline-block;
  background: var(--green-dim);
  border: 1px solid rgba(52,211,153,0.3);
  color: var(--green);
  font-size: 0.82rem;
  padding: 5px 16px;
  border-radius: 100px;
  margin-bottom: 20px;
  letter-spacing: 0.5px;
}
.hero-title {
  font-size: clamp(2.2rem, 6vw, 3.8rem);
  font-weight: 900;
  line-height: 1.2;
  margin-bottom: 18px;
  background: linear-gradient(135deg, #f0f6ff 0%, #38bdf8 50%, #34d399 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.hero-sub {
  font-size: 1.05rem;
  color: var(--muted);
  line-height: 1.8;
  margin-bottom: 36px;
  max-width: 600px;
  margin-left: auto;
  margin-right: auto;
}

/* quick-access */
.quick-links {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12px;
  margin-bottom: 56px;
}
.ql-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 11px 20px;
  border-radius: 12px;
  border: 1px solid rgba(56,189,248,0.25);
  background: var(--card-bg);
  color: var(--white);
  text-decoration: none;
  font-size: 0.9rem;
  font-weight: 600;
  font-family: inherit;
  cursor: pointer;
  transition: all .25s;
  white-space: nowrap;
}
.ql-btn .icon { font-size: 1.15rem; }
.ql-btn:hover { transform: translateY(-3px); border-color: var(--sky); color: var(--sky); box-shadow: 0 8px 24px rgba(56,189,248,0.2); }

/* ─── TEAM ─── */
.section-heading {
  text-align: center;
  margin-bottom: 48px;
}
.section-heading h2 {
  font-size: clamp(1.5rem, 4vw, 2.4rem);
  font-weight: 800;
  color: var(--white);
  margin-bottom: 10px;
}
.section-heading .line {
  width: 64px;
  height: 3px;
  background: linear-gradient(90deg, var(--sky), var(--green));
  border-radius: 2px;
  margin: 0 auto;
}

.team-grid {
  display: flex;
  justify-content: center;
  align-items: flex-start;
  flex-wrap: wrap;
  gap: 32px;
  position: relative;
}

/* member card */
.member-card {
  background: var(--card-bg);
  border: 1px solid rgba(56,189,248,0.18);
  border-radius: 20px;
  padding: 28px 20px 22px;
  width: 210px;
  text-align: center;
  cursor: pointer;
  transition: transform .3s, box-shadow .3s;
  position: relative;
  overflow: hidden;
}
.member-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(56,189,248,0.05) 0%, transparent 60%);
  pointer-events: none;
}
.member-card:hover {
  transform: translateY(-8px) scale(1.02);
  box-shadow: 0 16px 48px rgba(56,189,248,0.22);
}
.member-card .avatar-wrap {
  width: 110px; height: 110px;
  border-radius: 50%;
  margin: 0 auto 16px;
  overflow: hidden;
  border: 3px solid rgba(56,189,248,0.35);
  position: relative;
}
.member-card .avatar-wrap img {
  width: 100%; height: 100%;
  object-fit: cover;
}
.avatar-placeholder {
  width: 100%; height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2.4rem;
  background: linear-gradient(135deg, #0d2d4a, #0a1e30);
  color: var(--sky);
}
.member-name {
  font-size: 0.92rem;
  font-weight: 700;
  color: var(--white);
  background: rgba(56,189,248,0.1);
  border: 1px solid rgba(56,189,248,0.2);
  border-radius: 8px;
  padding: 7px 10px;
  line-height: 1.4;
}

/* LEADER card */
.member-card.leader {
  width: 250px;
  border: 2px solid var(--gold);
  box-shadow: 0 0 30px var(--gold-dim), 0 8px 32px rgba(0,0,0,0.5);
  animation: leaderPulse 3s ease-in-out infinite;
}
@keyframes leaderPulse {
  0%, 100% { box-shadow: 0 0 30px var(--gold-dim), 0 8px 32px rgba(0,0,0,0.5); }
  50% { box-shadow: 0 0 55px rgba(240,192,64,0.45), 0 8px 32px rgba(0,0,0,0.5); }
}
.member-card.leader:hover {
  transform: translateY(-10px) scale(1.04);
  box-shadow: 0 0 70px rgba(240,192,64,0.5), 0 20px 56px rgba(0,0,0,0.6);
  animation: none;
}
.member-card.leader .avatar-wrap {
  width: 130px; height: 130px;
  border: 3px solid var(--gold);
  box-shadow: 0 0 20px var(--gold-dim);
}
.member-card.leader .member-name {
  background: var(--gold-dim);
  border-color: rgba(240,192,64,0.4);
  color: var(--gold);
  font-size: 0.95rem;
}
.leader-star {
  position: absolute;
  top: 12px;
  left: 12px;
  font-size: 1.3rem;
  animation: spinStar 4s linear infinite;
}
@keyframes spinStar {
  0% { transform: rotate(0deg) scale(1); }
  50% { transform: rotate(180deg) scale(1.3); }
  100% { transform: rotate(360deg) scale(1); }
}
.leader-badge {
  display: inline-block;
  background: var(--gold-dim);
  border: 1px solid rgba(240,192,64,0.4);
  color: var(--gold);
  font-size: 0.72rem;
  padding: 3px 10px;
  border-radius: 100px;
  margin-bottom: 10px;
}
.shine-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(105deg, transparent 40%, rgba(240,192,64,0.08) 50%, transparent 60%);
  background-size: 200% 200%;
  animation: shineMove 3s linear infinite;
  pointer-events: none;
  border-radius: inherit;
}
@keyframes shineMove {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ─── NAV SECTION BUTTONS ─── */
.section-nav {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16px;
  margin-top: 56px;
  flex-wrap: wrap;
}
.snav-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 11px 22px;
  border-radius: 12px;
  border: 1px solid rgba(56,189,248,0.25);
  background: var(--card-bg);
  color: var(--sky);
  font-family: inherit;
  font-size: 0.9rem;
  font-weight: 600;
  cursor: pointer;
  transition: all .2s;
}
.snav-btn:hover { background: var(--sky-dim); box-shadow: 0 4px 20px rgba(56,189,248,0.2); }
.snav-btn.home { color: var(--green); border-color: rgba(52,211,153,0.25); }
.snav-btn.home:hover { background: var(--green-dim); }

/* ─── CONTENT SECTIONS ─── */
.content-section {
  display: none;
  animation: fadeIn .4s ease;
}
.content-section.active { display: block; }
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(18px); }
  to { opacity: 1; transform: translateY(0); }
}

/* section hero bar */
.section-hero-bar {
  background: linear-gradient(135deg, var(--navy), #0a2035);
  border: 1px solid rgba(56,189,248,0.15);
  border-radius: var(--radius);
  padding: 36px 40px;
  margin-bottom: 40px;
  position: relative;
  overflow: hidden;
}
.section-hero-bar::after {
  content: '';
  position: absolute;
  top: 0; right: 0;
  width: 300px; height: 100%;
  background: radial-gradient(ellipse at right center, rgba(56,189,248,0.07) 0%, transparent 70%);
  pointer-events: none;
}
.section-hero-bar h1 {
  font-size: clamp(1.4rem, 3.5vw, 2rem);
  font-weight: 800;
  color: var(--white);
  margin-bottom: 8px;
}
.section-hero-bar p {
  color: var(--muted);
  font-size: 0.95rem;
  line-height: 1.7;
  max-width: 600px;
}
.section-icon {
  position: absolute;
  left: 40px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 4rem;
  opacity: 0.12;
}

/* ─── INFO CARDS GRID ─── */
.info-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 24px;
  margin-bottom: 32px;
}
.info-card {
  background: var(--card-bg);
  border: 1px solid rgba(56,189,248,0.14);
  border-radius: var(--radius);
  padding: 24px;
  transition: transform .25s, box-shadow .25s;
}
.info-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 12px 36px rgba(56,189,248,0.15);
}
.info-card .card-icon {
  font-size: 2.2rem;
  margin-bottom: 14px;
  display: block;
}
.info-card h3 {
  font-size: 1rem;
  font-weight: 700;
  color: var(--sky);
  margin-bottom: 8px;
}
.info-card p {
  font-size: 0.875rem;
  color: var(--muted);
  line-height: 1.7;
}

/* stat cards */
.stat-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: 18px;
  margin-bottom: 32px;
}
.stat-card {
  background: var(--card-bg);
  border: 1px solid rgba(52,211,153,0.18);
  border-radius: var(--radius);
  padding: 22px 16px;
  text-align: center;
}
.stat-card .stat-num {
  font-size: 2rem;
  font-weight: 900;
  color: var(--green);
  line-height: 1;
  margin-bottom: 6px;
}
.stat-card .stat-label {
  font-size: 0.8rem;
  color: var(--muted);
}

/* whisper cards */
.whisper-list {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 20px;
}
.whisper-card {
  background: var(--card-bg);
  border-right: 4px solid var(--green);
  border-radius: var(--radius);
  padding: 22px 20px;
  transition: transform .2s;
}
.whisper-card:hover { transform: translateX(-4px); }
.whisper-card .wq {
  font-size: 0.95rem;
  font-style: italic;
  color: var(--white);
  line-height: 1.8;
  margin-bottom: 10px;
}
.whisper-card .wa {
  font-size: 0.78rem;
  color: var(--green);
  font-weight: 700;
}

/* ─── FILE CARDS ─── */
.files-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 24px;
}
.file-card {
  background: var(--card-bg);
  border: 1px solid rgba(56,189,248,0.16);
  border-radius: var(--radius);
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  transition: transform .25s, box-shadow .25s;
}
.file-card:hover { transform: translateY(-5px); box-shadow: 0 12px 36px rgba(56,189,248,0.15); }
.file-card-header {
  display: flex;
  align-items: center;
  gap: 14px;
}
.file-icon {
  width: 50px; height: 50px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  flex-shrink: 0;
}
.file-icon.ppt { background: linear-gradient(135deg, #c0392b, #8e1616); }
.file-icon.vid { background: linear-gradient(135deg, #6c3483, #1a0533); }
.file-icon.doc { background: linear-gradient(135deg, #1a6fa0, #0a2d42); }
.file-icon.inf { background: linear-gradient(135deg, #0e7c57, #053422); }
.file-card h3 {
  font-size: 0.98rem;
  font-weight: 700;
  color: var(--white);
  line-height: 1.4;
}
.file-card p {
  font-size: 0.82rem;
  color: var(--muted);
  line-height: 1.6;
  flex: 1;
}
.file-actions {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}
.btn-file {
  flex: 1;
  min-width: 100px;
  padding: 9px 14px;
  border-radius: 10px;
  border: 1px solid rgba(56,189,248,0.25);
  background: var(--sky-dim);
  color: var(--sky);
  font-family: inherit;
  font-size: 0.82rem;
  font-weight: 600;
  cursor: pointer;
  transition: all .2s;
  text-align: center;
}
.btn-file:hover { background: rgba(56,189,248,0.28); }
.btn-file.focus-btn {
  border-color: rgba(52,211,153,0.25);
  background: var(--green-dim);
  color: var(--green);
}
.btn-file.focus-btn:hover { background: rgba(52,211,153,0.25); }

/* preview area */
.preview-area {
  background: #060c16;
  border: 1px solid rgba(56,189,248,0.12);
  border-radius: 12px;
  overflow: hidden;
  height: 220px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.preview-area iframe {
  width: 100%;
  height: 100%;
  border: none;
  display: block;
}
.preview-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  color: var(--muted);
  font-size: 0.85rem;
  text-align: center;
}
.preview-placeholder .pi { font-size: 2rem; }
.btn-load-preview {
  padding: 8px 18px;
  border-radius: 8px;
  border: 1px solid rgba(56,189,248,0.3);
  background: var(--sky-dim);
  color: var(--sky);
  font-family: inherit;
  font-size: 0.8rem;
  cursor: pointer;
  transition: all .2s;
}
.btn-load-preview:hover { background: rgba(56,189,248,0.25); }

/* focus modal */
#focus-modal {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(4,9,18,0.95);
  z-index: 300;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 16px;
}
#focus-modal.open { display: flex; }
#focus-modal iframe {
  width: 90vw;
  height: 78vh;
  border: none;
  border-radius: 12px;
}
.focus-close {
  padding: 10px 28px;
  border-radius: 10px;
  border: 1px solid rgba(56,189,248,0.3);
  background: var(--sky-dim);
  color: var(--sky);
  font-family: inherit;
  font-size: 0.9rem;
  cursor: pointer;
}

/* ─── IMAGE MODAL ─── */
#img-modal {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(4,9,18,0.93);
  z-index: 200;
  align-items: center;
  justify-content: center;
}
#img-modal.open { display: flex; }
#img-modal .modal-inner {
  position: relative;
  max-width: 90vw;
  max-height: 85vh;
}
#img-modal img {
  max-width: 85vw;
  max-height: 80vh;
  border-radius: 16px;
  box-shadow: 0 24px 80px rgba(0,0,0,0.8);
}
#img-modal .close-btn {
  position: absolute;
  top: -14px;
  left: -14px;
  width: 36px; height: 36px;
  border-radius: 50%;
  background: var(--sky-dim);
  border: 1px solid var(--sky);
  color: var(--sky);
  font-size: 1.1rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ─── SCROLL REVEAL ─── */
.reveal { opacity: 0; transform: translateY(30px); transition: opacity .6s ease, transform .6s ease; }
.reveal.visible { opacity: 1; transform: translateY(0); }

/* ─── RESPONSIVE ─── */
@media (max-width: 768px) {
  nav { padding: 0 14px; }
  .nav-links { display: none; }
  .team-grid { flex-direction: column; align-items: center; }
  .member-card { width: 200px; }
  .member-card.leader { width: 230px; }
  .section-hero-bar { padding: 24px 20px; }
  .section-icon { display: none; }
  .container { padding: 0 14px; }
}

/* ─── SCROLLBAR ─── */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: var(--deep); }
::-webkit-scrollbar-thumb { background: rgba(56,189,248,0.3); border-radius: 3px; }

/* tab nav */
.tab-nav {
  display: flex;
  gap: 8px;
  margin-bottom: 28px;
  flex-wrap: wrap;
}
.tab-btn {
  padding: 8px 18px;
  border-radius: 10px;
  border: 1px solid rgba(56,189,248,0.2);
  background: transparent;
  color: var(--muted);
  font-family: inherit;
  font-size: 0.85rem;
  cursor: pointer;
  transition: all .2s;
}
.tab-btn.active, .tab-btn:hover {
  background: var(--sky-dim);
  color: var(--sky);
  border-color: rgba(56,189,248,0.4);
}
</style>
</head>
<body>

<!-- Background -->
<canvas id="bg-canvas"></canvas>
<div class="aurora">
  <div class="aurora-blob"></div>
  <div class="aurora-blob"></div>
  <div class="aurora-blob"></div>
</div>

<!-- NAV -->
<nav>
  <div class="nav-logo">
    <span class="leaf">🌿</span>
    <span>وعي تربوي أخضر</span>
  </div>
  <ul class="nav-links">
    <li><a href="#" class="active" onclick="showSection('home')">الرئيسية</a></li>
    <li><a href="#" onclick="showSection('green-uni')">الجامعة الخضراء</a></li>
    <li><a href="#" onclick="showSection('green-schools')">المدارس الخضراء</a></li>
    <li><a href="#" onclick="showSection('whispers')">همسات تربوية</a></li>
    <li><a href="#" onclick="showSection('indicators')">مؤشرات بيئية</a></li>
    <li><a href="#" onclick="showSection('resources')">الموارد</a></li>
  </ul>
